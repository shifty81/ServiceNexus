PORT=3001
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development

# Remote hosting configuration
# Set to a comma-separated list of allowed origins for CORS, or * for all
CORS_ORIGIN=*
# Set to true when behind a reverse proxy (nginx, cloud load balancer, etc.)
TRUST_PROXY=false
# Rate limiting: window in milliseconds and max requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
